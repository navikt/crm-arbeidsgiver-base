    <formulas>
        <name>EnquiryTitleBasedOnTheme</name>
        <dataType>String</dataType>
        <expression>IF(
  ISPICKVAL({!OutcomeThemeScreen}, &quot;Rekruttere og inkludere&quot;),
  &quot;Ønsker hjelp til å rekruttere og inkludere arbeidstakere&quot;,
  IF(
    ISPICKVAL({!OutcomeThemeScreen}, &quot;Forebygge og redusere fravær&quot;),
    &quot;Ønsker hjelp til å forebygge og redusere sykefravær&quot;,
    &quot;&quot;
  )
)</expression>
    </formulas>
    <formulas>
        <name>LastTextOrSavedText</name>
        <dataType>String</dataType>
        <expression>IF({!OutcomeTextComments} = null, {!Text.conversationNote}, {!OutcomeTextComments})</expression>
    </formulas>
    <formulas>
        <name>navUnitArbeidslivsenterName</name>
        <dataType>String</dataType>
        <expression>IF({!navUnitRegionFromAccount} = &quot;Øst-Viken&quot;, &quot;NAV Arbeidslivssenter Øst-Viken&quot;,
IF({!navUnitRegionFromAccount} = &quot;Oslo&quot;, &quot;NAV Arbeidslivssenter Oslo&quot;,
IF({!navUnitRegionFromAccount} = &quot;Innlandet&quot;, &quot;NAV Arbeidslivssenter Innlandet&quot;,
IF({!navUnitRegionFromAccount} = &quot;Vest-Viken&quot;, &quot;NAV Arbeidslivssenter Vest-Viken&quot;,
IF({!navUnitRegionFromAccount} = &quot;Vestfold og Telemark&quot;, &quot;NAV Arbeid og helse Vestfold og Telemark&quot;,
IF({!navUnitRegionFromAccount} = &quot;Agder&quot;, &quot;NAV Arbeidslivssenter Agder&quot;,
IF({!navUnitRegionFromAccount} = &quot;Rogaland&quot;, &quot;NAV Arbeidslivssenter Rogaland&quot;,
IF({!navUnitRegionFromAccount} = &quot;Vestland&quot;, &quot;NAV Arbeidslivssenter Vestland&quot;,
IF({!navUnitRegionFromAccount} = &quot;Møre og Romsdal&quot;, &quot;NAV Arbeidslivssenter Møre og Romsdal&quot;,
IF({!navUnitRegionFromAccount} = &quot;Nordland&quot;, &quot;NAV Arbeidslivssenter Nordland&quot;,
IF({!navUnitRegionFromAccount} = &quot;Troms og Finnmark&quot;, &quot;NAV Arbeidslivssenter Troms og Finnmark&quot;,
IF({!navUnitRegionFromAccount} = &quot;Trøndelag&quot;, &quot;NAV Arbeidslivssenter Trøndelag&quot;,
NULL
))))))))))))</expression>
    </formulas>
