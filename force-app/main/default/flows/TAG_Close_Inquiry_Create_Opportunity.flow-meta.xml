    <formulas>
        <name>ActivityTypeToOpportunityCategoryMapping</name>
        <dataType>String</dataType>
        <expression>CASE( TEXT({!recordId.ActivityType__c}),
&apos;Rekruttere og inkludere&apos;, &apos;Skal ansette&apos;,
&apos;Forebygge sykefravær og redusere frafall&apos;, &apos;Forebygge sykefravær&apos;,
&apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>CreateOpportunityURL</name>
        <dataType>String</dataType>
        <expression>&apos;/lightning/o/CustomOpportunity__c/new?defaultFieldValues=Account__c=&apos;&amp;{!opportunity.Account__c}
&amp;&apos;,Contact__c=&apos;&amp;{!opportunity.Contact__c}
&amp;&apos;,TAG_NavUnit__c=&apos;&amp;{!opportunity.TAG_NavUnit__c}
&amp;&apos;,INT_MunicipalityNumber__c=&apos;&amp;{!opportunity.INT_MunicipalityNumber__c}
&amp;&apos;,Source__c=&apos;&amp;TEXT({!opportunity.Source__c})
&amp;&apos;,InclusionStage__c=&apos;&amp;TEXT({!opportunity.InclusionStage__c})
&amp;&apos;,TAG_EmployerInquiry__c=&apos;&amp;{!opportunity.TAG_EmployerInquiry__c}</expression>
    </formulas>
