<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MustBeClosedWhenHaveReason</fullName>
    <active>true</active>
    <description>Krever at henvendelsen må lukkes når man angir en sluttkode.</description>
    <errorConditionFormula>AND( NOT(ISPICKVAL(TAG_ClosedReason__c, &quot;&quot;)),  NOT( ISPICKVAL(TAG_Status__c, &apos;Fullført&apos;)) )</errorConditionFormula>
    <errorDisplayField>TAG_Status__c</errorDisplayField>
    <errorMessage>Status må settes til &quot;Fullført&quot; når &quot;Hva skjer videre?&quot; er fylt ut.</errorMessage>
</ValidationRule>
