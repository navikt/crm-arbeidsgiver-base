<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TAG_InquiryDate__c</fullName>
    <description>Brukes for å sortere henvendelser i tidslinjen basert på svarfrist e,ler dato lukket</description>
    <formula>IF(ISBLANK(TAG_ResolvedDate__c),  TAG_DueDate__c,  DATEVALUE(TAG_ResolvedDate__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>InquiryDate</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Date</type>
</CustomField>
